<%- include('header')%>
    <!-- ===== PORTFOLIO SECTION ===== -->
    <section id="portfolio" class="portfolio">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Portfolio</span>
                <h2 class="section-title">Featured Projects</h2>
                <p class="section-desc">A selection of my recent work across various domains</p>
            </div>
            
            <!-- Filter Buttons -->
            <div class="portfolio-filter">
                <button class="filter-btn active" data-filter="all">All</button>
                <% if (projects && projects.length) {
                    const seen = {};
                    for (let i = 0; i < projects.length; i++) {
                        const type = (projects[i].ptype || '').trim();
                        const key = type.toLowerCase();
                        if (type && !seen[key]) {
                            seen[key] = true;
                %>
                    <button class="filter-btn" data-filter="<%= key %>"><%= type %></button>
                <%
                        }
                    }
                } %>
            </div>
            
            <!-- Portfolio Grid -->
            <div class="portfolio-grid">
                <% if (projects && projects.length) { %>
                    <% for (let i = 0; i < projects.length; i++) { %>
                        <div class="portfolio-item" data-category="<%= (projects[i].ptype || '').toLowerCase() %>">
                            <img src="/<%= projects[i].pimg %>" alt="<%= projects[i].pname %>" />
                            <div class="portfolio-overlay">
                                <h3><%= projects[i].pname %></h3>
                                <p><%= projects[i].ptype %></p>
                                <a href="/<%= projects[i].pimg %>" class="portfolio-link"><i class="fas fa-search-plus"></i></a>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <p style="margin:0; opacity:0.8;">No projects found.</p>
                <% } %>
            </div>
            <br>
    <div class="stats-text-block">
     <a href="/contact" class="link-with-arrow group">
       View contact <i class="fas fa-arrow-right"></i>
     </a>
    </div>
        </div>
        </div>
    </section>
<%- include('footer')%>
