<%- include('header')%>
    <!-- ===== HERO SECTION ===== -->
    <section id="hero" class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <div class="hero-text">
                <span class="hero-greeting">Hello, I'm</span>
                <h1>Alex Rivera</h1>
                <h2 id="typingText">Creative Developer</h2>
                <p>I craft digital experiences that blend design thinking with clean, efficient code.</p>
                <div class="hero-buttons">
                    <a href="#portfolio" class="btn btn-primary">View My Work</a>
                    <a href="#contact" class="btn btn-secondary">Let's Talk</a>
                </div>
                <div class="hero-social">
                    <a href="#" aria-label="GitHub"><i class="fab fa-github"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                    <a href="#" aria-label="Dribbble"><i class="fab fa-dribbble"></i></a>
                </div>
            </div>
            <div class="hero-image">
                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&h=500&fit=crop&crop=face" alt="Alex Rivera - Creative Developer" />
            </div>
        </div>
        <div class="scroll-indicator">
            <span>Scroll</span>
            <i class="fas fa-chevron-down"></i>
        </div>
    </section>
<%- include('footer')%>