<%- include('header')%>
    <!--HERO SECTION-->
    <section id="hero" class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <div class="hero-text">
                <span class="hero-greeting">Hello, I'm</span>
                <h1><%= (hero && hero.hname) ? hero.hname : 'Your Name' %></h1>
                <h2 id="typingText" data-phrases="<%= (hero && hero.hprofession) ? hero.hprofession : 'Creative Developer' %>"><%= (hero && hero.hprofession) ? hero.hprofession : 'Creative Developer' %></h2>
                <p><%= (hero && hero.habout) ? hero.habout : '' %></p>
                <div class="hero-buttons">
                    <a href="/portfolio" class="btn btn-primary">View My Work</a>
                    <a href="/contact" class="btn btn-secondary">Let's Talk</a>
                </div>
                <div class="hero-social">
                    <% if (social_media) { %>
                        <% if (social_media.github) { %><a href="<%= social_media.github %>" target="_blank" aria-label="GitHub"><i class="fab fa-github"></i></a><% } %>
                        <% if (social_media.linkedin) { %><a href="<%= social_media.linkedin %>" target="_blank" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><% } %>
                        <% if (social_media.twitter) { %><a href="<%= social_media.twitter %>" target="_blank" aria-label="Twitter"><i class="fab fa-twitter"></i></a><% } %>
                        <% if (social_media.instagram) { %><a href="<%= social_media.instagram %>" target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a><% } %>
                        <% if (social_media.youtube) { %><a href="<%= social_media.youtube %>" target="_blank" aria-label="YouTube"><i class="fab fa-youtube"></i></a><% } %>
                        <% if (social_media.facebook) { %><a href="<%= social_media.facebook %>" target="_blank" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a><% } %>
                    <% } %>
                </div>
            </div>
            <div class="hero-image">
                <% if (hero && hero.himg) { %>
                    <img src="/<%= hero.himg %>" alt="<%= hero.hname || 'Profile' %>" />
                <% } else { %>
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&h=500&fit=crop&crop=face" alt="Profile" />
                <% } %>
            </div>
        </div>
    </section>
<%- include('footer')%>
