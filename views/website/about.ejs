<%- include('header')%>
    <!-- ===== ABOUT SECTION ===== -->
    <section id="about" class="about">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">About Me</span>
                <h2 class="section-title">Turning Ideas Into Reality</h2>
                <p class="section-desc">Get to know more about my background and what drives me</p>
            </div>
            
            <div class="about-grid">
                <div class="about-image">
                    <% if (about && about.aimg) { %>
                        <img src="/<%= about.aimg %>" alt="<%= about.aname || 'About' %>" />
                    <% } else { %>
                        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=700&fit=crop&crop=face" alt="About" />
                    <% } %>
                    <div class="about-experience-badge">
                        <span><%= (about && about.aexperience) ? about.aexperience : '0' %></span>
                        Years Experience
                    </div>
                </div>
                <div class="about-content">
                    <h3><%= (about && about.aprofession) ? about.aprofession : 'Creative Developer' %></h3>
                    <p><%= (about && about.asummary) ? about.asummary : '' %></p>
                    
                    <div class="about-info-grid">
                        <div class="info-item">
                            <span class="info-label">Name:</span>
                            <span class="info-value"><%= (about && about.aname) ? about.aname : '-' %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Email:</span>
                            <span class="info-value"><%= (about && about.aemail) ? about.aemail : '-' %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Location:</span>
                            <span class="info-value"><%= (about && about.alocation) ? about.alocation : '-' %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Freelance:</span>
                            <span class="info-value"><%= (about && about.afreelance) ? about.afreelance : '-' %></span>
                        </div>
                    </div>
                    
                    <a href="/contact" class="btn btn-primary">Get In Touch</a>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ===== STATISTICS COUNTER ===== -->
    <section class="statistics">
        <div class="container">
            <div class="stat-grid">
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.aprojectcom) ? about.aprojectcom : 0 %>">0</span>
                    <span class="stat-label">Projects Completed</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.ahappyclients) ? about.ahappyclients : 0 %>">0</span>
                    <span class="stat-label">Happy Clients</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.aaward) ? about.aaward : 0 %>">0</span>
                    <span class="stat-label">Awards Won</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.ayear) ? about.ayear : 0 %>">0</span>
                    <span class="stat-label">Years Experience</span>
                </div>
            </div>
        </div>
    </section>
    
<%- include('footer')%>
