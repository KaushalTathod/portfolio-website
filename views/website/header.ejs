<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alex Rivera | Creative Portfolio</title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="Alex Rivera - Creative Developer & Designer. Modern portfolio showcasing web development, UI/UX design, and digital solutions." />
    <meta name="robots" content="index, follow" />
    
    <!-- CSS Files -->
    <link rel="stylesheet" href="/website/style.css" />
    <link rel="stylesheet" href="/website/responsive.css" />
    
    <!-- Font Awesome (for icons) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
    
    <!-- ===== LOADING SCREEN ===== -->
    <div id="loader">
        <div class="loader-spinner"></div>
    </div>
    
    <!-- ===== BACK TO TOP BUTTON ===== -->
    <button id="back-to-top" aria-label="Back to top">
        <i class="fas fa-arrow-up"></i>
    </button>
    
<!-- ===== STICKY NAVIGATION ===== -->
<header id="navbar">
    <div class="container nav-container">
        <div class="logo">
            <a href="/">
                <img src="/<%= contact.logo %>" alt="Logo" width="150" height="50">
            </a>
        </div>

        <!-- Mobile Menu Toggle -->
        <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <!-- Navigation Links -->
        <nav id="navMenu">
            <ul>
                <li><a href="/" class="active"><i class="fas fa-home"></i><span class="nav-text">Home</span></a></li>
                <li><a href="/about"><i class="fas fa-user"></i><span class="nav-text">About</span></a></li>
                <li><a href="/blog"><i class="fas fa-blog"></i><span class="nav-text">Blog</span></a></li>
                <li><a href="/portfolio"><i class="fas fa-project-diagram"></i><span class="nav-text">Projects</span></a></li>
                <li><a href="/contact"><i class="fas fa-envelope"></i><span class="nav-text">Contact</span></a></li>
            </ul>

            <!-- Dark Mode Toggle -->
            <button id="themeToggle" aria-label="Toggle dark mode">
                <i class="fas fa-moon"></i>
            </button>
        </nav>

    </div>
    
</header>
<div class="galaxy-bg" id="galaxyBg">
    <div class="stars-layer" id="starsLayer"></div>
</div>