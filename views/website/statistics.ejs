    <%- include('header')%>
    <!-- ===== STATISTICS COUNTER ===== -->
    <section class="statistics">
        <div class="container">
            <div class="stat-grid">
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.aprojectcom) ? about.aprojectcom : 0 %>">0</span>
                    <span class="stat-label">Projects Completed</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.ahappyclients) ? about.ahappyclients : 0 %>">0</span>
                    <span class="stat-label">Happy Clients</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.aaward) ? about.aaward : 0 %>">0</span>
                    <span class="stat-label">Awards Won</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="<%= (about && about.ayear) ? about.ayear : 0 %>">0</span>
                    <span class="stat-label">Years Experience</span>
                </div>
            </div>
        </div>
    </section>

    <section class="resume">
        <div class="container">
            <div class="resume-grid">
                <!-- Experience Timeline -->
                <div class="timeline-container">
                    <h3>Experience</h3>
                    
                    <div class="timeline">
                        <% if (experience && experience.length) { %>
                            <% for (let i = 0; i < experience.length; i++) { %>
                                <div class="timeline-item">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-content">
                                        <span class="timeline-date"><%= experience[i].exp_duration %></span>
                                        <h4><%= experience[i].exp_position %></h4>
                                        <p class="timeline-company"><%= experience[i].exp_company %></p>
                                        <p><%= experience[i].exp_desc %></p>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <p style="margin:0; opacity:0.8;">No experience found.</p>
                        <% } %>
                    </div>
                    
                    <h3 style="margin-top: 40px;">Education</h3>
                    <div class="timeline">
                        <% if (education && education.length) { %>
                            <% for (let i = 0; i < education.length; i++) { %>
                                <div class="timeline-item">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-content">
                                        <span class="timeline-date"><%= education[i].eyear %></span>
                                        <h4><%= education[i].edegree %></h4>
                                        <p class="timeline-company"><%= education[i].eunivercity %></p>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <p style="margin:0; opacity:0.8;">No education found.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>
<%- include('footer')%>
