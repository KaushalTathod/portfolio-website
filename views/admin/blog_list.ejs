<%- include('header') %>

<div class="page-content">
    <div class="container-fluid">

        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold">Blog List</h2>
                <p class="text-muted mb-0">Manage Blogs</p>
            </div>

            <div>
                <a href="/admin/blog_add" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Add Blog
                </a>
            </div>
        </div>

        <!-- Blog Table -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="70">Id</th>
                            <th>Date</th>
                            <th>Title</th>
                            <th>Content</th>
                            <th>Image</th>
                            <th width="170">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% for(let i = 0; i < blog.length; i++){ %>
                        <tr>
                            <td><%= i + 1 %></td>

                            <td>
                                <%= blog[i].bdate %>
                            </td>

                            <td>
                                <strong><%= blog[i].btitle %></strong>
                            </td>

                            <td>
                                <%= blog[i].bcontent %>
                            </td>

                            <td>
                                <img src="/<%= blog[i].bimg %>" width="80" height="60">
                            </td>

                            <td>
                                <a href="/admin/delete_blog/<%= blog[i].bid %>" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i>
                                </a>

                                <a href="/admin/edit_blog/<%= blog[i].bid %>" class="btn btn-warning btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>

                </table>

            </div>
        </div>

    </div>
</div>

<%- include('footer') %>