<%- include('header') %>

<div class="page-content">
    <div class="container-fluid">

        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1">Add Blog</h1>
                <p class="text-muted small mb-0">Add New Blog Post</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">

                        <form action="/admin/blog_add_save" method="post" enctype="multipart/form-data">

                            <div class="mb-3">
                                <label class="form-label">Blog Date</label>
                                <input type="date" name="bdate" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Blog Title</label>
                                <input type="text" name="btitle" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Blog Content</label>
                                <textarea type="text" name="bcontent" class="form-control" rows="5" required></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Blog Image</label>
                                <input type="file" name="bimg" class="form-control" required>
                            </div>

                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Save Blog
                            </button>

                        </form>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('footer') %>