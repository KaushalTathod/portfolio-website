<%- include('header') %>

<div class="page-content">
    <div class="container-fluid">

        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1">Edit Education</h1>
                <p class="text-muted small mb-0">Modify your education details</p>
            </div>
        </div>
        <div class="crow g-4">
            <div class="col-12">
                <form action="/admin/update_education" method="post">
                    <input type="hidden" name="eid" value="<%= education.eid %>">
                    <label>Education Duration</label>
                    <input type="text" name="eyear" value="<%= education.eyear %>" class="form-control mb-4">
                    <label>Degree</label>
                    <input type="text" name="edegree" value="<%= education.edegree %>" class="form-control mb-4">
                    <label>University</label>
                    <input type="text" name="eunivercity" value="<%= education.eunivercity %>" class="form-control mb-4">
                    <button class="btn btn-primary ">Update</button>
                </form>
            </div>
        </div>

    </div>
</div>

<%- include('footer') %>
