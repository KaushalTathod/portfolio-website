<%- include('header') %>

<div class="page-content">
    <div class="container-fluid">

        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold">Service List </h2>
                <p class="text-muted mb-0">Welcome back, Here's your overview</p>
            </div>
            <div>
                <a href="/admin/services_add" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Add Service
                </a>
            </div>
        </div>

        <!-- Skill Table -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="70">Id</th>
                            <th>Services Techonology</th>
                            <th width="180">Discription</th>
                            <th width="170">Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% for(let i=0;i<services.length;i++){ %>
                        <tr>
                            <td><%= i+1 %></td>
                            <td><strong><%= services[i].ser_technology %></strong></td>
                            <td><strong><%= services[i].ser_discription %></strong></td>
                            <td>
                                <a href="/admin/delete_service/<%= services[i].sid %>" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i>
                                </a>

                                <a href="/admin/edit_service/<%= services[i].sid %>" class="btn btn-warning btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                        <% } %>
                        
                    </tbody>

                </table>

            </div>
        </div>

    </div>
</div>

<%- include('footer') %>