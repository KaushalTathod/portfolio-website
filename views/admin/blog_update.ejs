<%- include('header') %>

<div class="page-content">
    <div class="container-fluid">

        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1">Update Blog</h1>
                <p class="text-muted small mb-0">Update Blog Information</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">

                        <form action="/admin/blog_update_save" method="post" enctype="multipart/form-data">

                            <input type="hidden" name="bid" value="<%= blog.bid %>">

                            <div class="mb-3">
                                <label class="form-label">Blog Date</label>
                                <input type="date" name="bdate" class="form-control"
                                    value="<%= blog.bdate %>">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Blog Title</label>
                                <input type="text" name="btitle" class="form-control"
                                    value="<%= blog.btitle %>">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Blog Content</label>
                                <textarea name="bcontent" rows="5" class="form-control"><%= blog.bcontent %></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Blog Image</label>
                                <input type="file" name="bimg" class="form-control">
                            </div>

                            <input type="hidden" name="old_img" value="<%= blog.bimg %>">

                            <div class="mb-3">
                                <label class="form-label">Current Image</label><br>
                                <img src="/<%= blog.bimg %>" width="150">
                            </div>

                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Update Blog
                            </button>

                        </form>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('footer') %>