<%- include('header')%>

            <!-- ===== DASHBOARD CONTENT ===== -->
            <div class="page-content">
                <div class="container-fluid">
                    <!-- Page Header -->
                    <div class="page-header d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="h3 mb-1">Dashboard</h1>
                            <p class="text-muted small mb-0">Welcome back, <%= username %>! Here's your overview</p>
                        </div>
                    </div>

                    <!-- Stat Cards -->
                    <div class="row g-4">
                        <div class="col-xl-3 col-lg-6 col-md-6">
                            <div class="stat-card">
                                <div class="stat-icon bg-primary">
                                    <i class="fas fa-folder-open"></i>
                                </div>
                                <div class="stat-info">
                                    <h3 class="stat-number" data-count="<%= projectsCount %>">0</h3>
                                    <p class="stat-label">Total Projects</p>
                                </div>
                                <div class="stat-change positive">
                                    <i class="fas fa-arrow-up"></i>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-xl-3 col-lg-6 col-md-6">
                            <div class="stat-card">
                                <div class="stat-icon bg-success">
                                    <i class="fas fa-blog"></i>
                                </div>
                                <div class="stat-info">
                                    <h3 class="stat-number" data-count="<%= blogCount %>">0</h3>
                                    <p class="stat-label">Blog Posts</p>
                                </div>
                                <div class="stat-change positive">
                                    <i class="fas fa-arrow-up"></i>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-xl-3 col-lg-6 col-md-6">
                            <div class="stat-card">
                                <div class="stat-icon bg-warning">
                                    <i class="fas fa-envelope"></i>
                                </div>
                                <div class="stat-info">
                                    <h3 class="stat-number" data-count="<%= messagesCount %>">0</h3>
                                    <p class="stat-label">Messages</p>
                                </div>
                                <div class="stat-change negative">
                                    <i class="fas fa-arrow-up"></i>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-xl-3 col-lg-6 col-md-6">
                            <div class="stat-card">
                                <div class="stat-icon bg-danger">
                                    <i class="fas fa-users"></i>
                                </div>
                                <div class="stat-info">
                                    <h3 class="stat-number" data-count="1240">0</h3>
                                    <p class="stat-label">Visitors</p>
                                </div>
                                <div class="stat-change positive">
                                    <i class="fas fa-arrow-up"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    

                    <!-- Recent Activity & Messages -->
                    <div class="row g-4 mt-2">
                        <div class="col-xl-7 col-lg-12">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h5 class="card-title mb-0">Recent Activity</h5>
                                    <a href="#" class="text-decoration-none small">View All</a>
                                </div>
                                <div class="card-body p-0">
                                    <div class="activity-list">
                                        <% if(recent_activities && recent_activities.length > 0) { %>
                                            <% recent_activities.forEach(function(activity) { %>
                                                <div class="activity-item">
                                                    <div class="activity-icon <%= activity.color %>">
                                                        <i class="<%= activity.icon %>"></i>
                                                    </div>
                                                    <div class="activity-content">
                                                        <p><%= activity.description %></p>
                                                        <small><%= new Date(activity.created_at).toLocaleString() %></small>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <div class="p-3 text-center text-muted">No recent activity.</div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-xl-5 col-lg-12">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h5 class="card-title mb-0">Recent Messages</h5>
                                    <a href="#" class="text-decoration-none small">View All</a>
                                </div>
                                <div class="card-body p-0">
                                    <div class="message-list">
                                        <% if(recent_messages && recent_messages.length > 0) { %>
                                            <% recent_messages.forEach(function(msg) { %>
                                                <div class="message-item <%= msg.is_read ? '' : 'unread' %>">
                                                    <div class="message-avatar">
                                                        <img src="https://ui-avatars.com/api/?name=<%= msg.name %>&size=40&background=6c63ff&color=fff" alt="Avatar" />
                                                    </div>
                                                    <div class="message-content">
                                                        <h6><%= msg.name %></h6>
                                                        <p><%= msg.message ? msg.message.substring(0, 40) + '...' : '' %></p>
                                                        <small>Recently</small>
                                                    </div>
                                                    <% if(!msg.is_read) { %>
                                                        <span class="badge bg-danger">New</span>
                                                    <% } %>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <div class="p-3 text-center text-muted">No recent messages.</div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
<%- include('footer')%>
