<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - Portfolio Admin</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="style.css" />
</head>
<body class="login-page">
    <div class="login-wrapper">
        <div class="login-container">
            <div class="login-brand text-center mb-4">
                <i class="fas fa-lock fa-3x text-primary"></i>
                <h2 class="mt-2 fw-bold">New <span class="text-primary">Password</span></h2>
                <p class="text-muted">Enter your new password below</p>
            </div>
            
            <div class="login-card card shadow-lg border-0">
                <div class="card-body p-5">
                    <% if(typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger"><%= error %></div>
                    <% } %>
                    
                    <form action="/admin/reset_password" method="POST">
                        <div class="mb-4">
                            <label for="new_password" class="form-label fw-semibold">
                                <i class="fas fa-key me-2 text-primary"></i>New Password
                            </label>
                            <input type="password" class="form-control form-control-lg" name="new_password" id="new_password" 
                                   placeholder="New Password" required minlength="4" />
                        </div>
                        <div class="mb-4">
                            <label for="confirm_password" class="form-label fw-semibold">
                                <i class="fas fa-check me-2 text-primary"></i>Confirm Password
                            </label>
                            <input type="password" class="form-control form-control-lg" name="confirm_password" id="confirm_password" 
                                   placeholder="Confirm Password" required minlength="4" />
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-save me-2"></i>Reset Password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
