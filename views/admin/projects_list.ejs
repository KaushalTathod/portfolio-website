<%- include('header') %>

<div class="page-content">
    <div class="container-fluid">

        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold">Project List</h2>
                <p class="text-muted mb-0">Manage Your Projects</p>
            </div>

            <div>
                <a href="/admin/projects" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Add Project
                </a>
            </div>
        </div>

        <!-- Project Table -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="70">Id</th>
                            <th>Project Name</th>
                            <th>Project Type</th>
                            <th>Image</th>
                            <th width="170">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% for(let i=0; i<project.length; i++){ %>
                        <tr>
                            <td><%= i+1 %></td>

                            <td>
                                <strong><%= project[i].pname %></strong>
                            </td>

                            <td>
                                <%= project[i].ptype %>
                            </td>

                            <td>
                                <img src="/<%= project[i].pimg %>" width="80" height="60">
                            </td>

                            <td>
                                <a href="/admin/delete_projects/<%= project[i].pid %>" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i>
                                </a>

                                <a href="/admin/edit_projects/<%= project[i].pid %>" class="btn btn-warning btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>

                </table>

            </div>
        </div>

    </div>
</div>

<%- include('footer') %>