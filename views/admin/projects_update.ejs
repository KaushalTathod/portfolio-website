<%- include('header') %>

<div class="page-content">
    <div class="container-fluid">

        <div class="page-header">
            <h1 class="h3 mb-1">Update Project</h1>
            <p class="text-muted small mb-0">Update Project Information</p>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">

                        <form action="/admin/project_update_save" method="post" enctype="multipart/form-data">

                            <input type="hidden" name="pid" value="<%= project.pid %>">

                            <div class="mb-3">
                                <label>Project Name</label>
                                <input type="text" name="pname" class="form-control"
                                    value="<%= project.pname %>">
                            </div>

                            <div class="mb-3">
                                <label>Project Type</label>
                                <input type="text" name="ptype" class="form-control"
                                    value="<%= project.ptype %>">
                            </div>

                            <div class="mb-3">
                                <label>Project Image</label>
                                <input type="file" name="pimg" class="form-control">
                            </div>

                            <input type="hidden" name="old_img" value="<%= project.pimg %>">

                            <div class="mb-3">
                                <label>Current Image</label><br>
                                <img src="/<%= project.pimg %>" width="150">
                            </div>

                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Update Project
                            </button>

                        </form>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('footer') %>